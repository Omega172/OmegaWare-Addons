{
  "schemaVersion": 1,
  "id": "omegaware-addons",
  "version": "${version}",
  "name": "OmegaWare Addons",
  "description": "Addons for Meteor Client",
  "authors": [
    "Omega172"
  ],
  "contact": {
    "repo": "https://github.com/Omega172/OmegaWare-Addons"
  },
  "icon": "assets/icon/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "xyz.omegaware.addon.OmegawareAddons"
    ]
  },
  "mixins": [
    "omegaware-addons.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "0,255,255"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
